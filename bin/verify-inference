#!/usr/bin/env ruby
# frozen_string_literal: true

# Verify TypeGuessr type inference against test_inference.rb expectations.
#
# Parses lines with "# => ExpectedType" comments, hovers over the last
# method call on each line, and checks if the hover result contains
# the expected type string.
#
# Usage:
#   bin/verify-inference sample/activerecord
#   bin/verify-inference sample/mongoid
#   bin/verify-inference sample/activerecord --verbose

require "open3"
require "json"

class LspClient
  def initialize(stdin, stdout)
    @stdin = stdin
    @stdout = stdout
    @request_id = 0
    @notification_handler = nil
  end

  def on_notification(&block)
    @notification_handler = block
  end

  def send_request(method, params)
    @request_id += 1
    message = { jsonrpc: "2.0", id: @request_id, method: method, params: params }
    write_message(message)
    read_response(@request_id)
  end

  def send_notification(method, params)
    message = { jsonrpc: "2.0", method: method, params: params }
    write_message(message)
  end

  def read_response(expected_id = nil)
    loop do
      msg = read_message
      return nil unless msg

      unless msg.key?("id")
        @notification_handler&.call(msg)
        next
      end

      next if expected_id && msg["id"] != expected_id

      return msg
    end
  end

  def drain_notifications(timeout: 0.1)
    start = Time.now
    while Time.now - start < timeout
      break unless @stdout.wait_readable(0.05)

      msg = read_message
      break unless msg

      @notification_handler&.call(msg) unless msg.key?("id")
    end
  end

  private def read_message
    header = ""
    loop do
      line = @stdout.gets
      return nil unless line
      break if line == "\r\n"

      header += line
    end

    content_length = header.match(/Content-Length: (\d+)/i)&.[](1)&.to_i
    return nil unless content_length

    body = @stdout.read(content_length)
    JSON.parse(body)
  end

  private def write_message(message)
    json = JSON.generate(message)
    @stdin.write("Content-Length: #{json.bytesize}\r\n\r\n#{json}")
    @stdin.flush
  end
end

class InferenceVerifier
  Expectation = Struct.new(:line, :col, :code, :expected)
  Result = Struct.new(:expectation, :actual, :status) # :pass, :fail, :no_hover

  def initialize(project_dir, verbose: false)
    @project_dir = File.expand_path(project_dir)
    @test_file = File.join(@project_dir, "test_inference.rb")
    @verbose = verbose
    @results = []
    @indexing_complete = false
    @opened_files = {}
  end

  def run
    abort "Error: #{@test_file} not found" unless File.exist?(@test_file)

    expectations = parse_expectations
    puts "Parsed #{expectations.size} expectations from test_inference.rb"
    puts

    start_server
    expectations.each { |exp| verify(exp) }
    print_report
  ensure
    shutdown_server
  end

  private def parse_expectations
    lines = File.readlines(@test_file)
    expectations = []

    lines.each_with_index do |line, idx|
      # Match lines with code followed by "# => ExpectedType"
      match = line.match(/^([^#]+?)\s+#\s*=>\s*(.+?)\s*$/)
      next unless match

      code = match[1].rstrip
      expected = match[2].strip.sub(/\s*\(.*\)\s*$/, "")

      # Skip if code part is blank or comment-only
      next if code.strip.empty?

      col = find_hover_column(code)
      next unless col

      expectations << Expectation.new(
        line: idx + 1,
        col: col,
        code: code.strip,
        expected: expected
      )
    end

    expectations
  end

  private def find_hover_column(code)
    # Find the last .method_name or ::method_name pattern in the code.
    # Returns the 1-indexed column of the method name start.
    #
    # Examples:
    #   "user.name"           -> col of 'n' in 'name'
    #   "User.find(1)"        -> col of 'f' in 'find'
    #   "user.posts.build"    -> col of 'b' in 'build'
    #   "user.name_changed?"  -> col of 'n' in 'name_changed?'
    #
    # Note: Uses \.method or ::method patterns only.
    # Single : (Ruby symbol like :name) is excluded to avoid
    # hovering over symbol arguments instead of method calls.

    last_pos = nil
    pos = 0
    while (m = code.match(/(?:\.|::)(\w+[?!]?)/, pos))
      last_pos = m.begin(1)
      pos = m.end(0)
    end

    last_pos ? last_pos + 1 : nil # 1-indexed
  end

  # --- LSP Server ---

  private def start_server
    puts "Starting ruby-lsp server in #{@project_dir}..."
    @stdin, @stdout, @stderr, @wait_thr = Open3.popen3(
      "bundle", "exec", "ruby-lsp",
      chdir: @project_dir
    )
    @client = LspClient.new(@stdin, @stdout)

    @client.on_notification { |msg| handle_notification(msg) }

    @stderr_thread = Thread.new do
      while (line = @stderr.gets)
        warn "  [stderr] #{line.strip}" if @verbose
      end
    rescue IOError
      nil
    end

    initialize_lsp
  end

  private def initialize_lsp
    root_uri = "file://#{@project_dir}"
    response = @client.send_request("initialize", {
                                      processId: Process.pid,
                                      rootUri: root_uri,
                                      capabilities: {
                                        textDocument: { hover: { contentFormat: %w[markdown plaintext] } },
                                        window: { workDoneProgress: true }
                                      },
                                      initializationOptions: {}
                                    })

    abort "Initialize error: #{response["error"]}" if response&.dig("error")

    @client.send_notification("initialized", {})
    puts "Waiting for indexing..."

    timeout = Time.now + 120
    @client.drain_notifications(timeout: 0.5) until @indexing_complete || Time.now > timeout

    if @indexing_complete
      puts "Indexing complete!"
    else
      puts "Timeout waiting for indexing, continuing anyway..."
    end
    puts
  end

  private def handle_notification(msg)
    return unless msg["method"] == "window/logMessage"

    message = msg.dig("params", "message") || ""
    return unless message.include?("[TypeGuessr]")

    puts "  #{message}" if @verbose
    @indexing_complete = true if message.include?("File indexing completed")
  end

  private def shutdown_server
    return unless @client

    @client.send_request("shutdown", nil)
    @client.send_notification("exit", nil)
    @stdin&.close
    @stdout&.close
    @stderr&.close
    @wait_thr&.value
  end

  # --- Verification ---

  private def verify(exp)
    uri = "file://#{@test_file}"

    unless @opened_files[uri]
      source = File.read(@test_file)
      @client.send_notification("textDocument/didOpen", {
                                  textDocument: { uri: uri, languageId: "ruby", version: 1, text: source }
                                })
      @opened_files[uri] = true
      sleep 1 # Give server time to process
    end

    response = @client.send_request("textDocument/hover", {
                                      textDocument: { uri: uri },
                                      position: { line: exp.line - 1, character: exp.col - 1 }
                                    })

    actual = extract_hover_content(response)

    status = if actual.nil?
               :no_hover
             elsif type_matches?(actual, exp.expected)
               :pass
             else
               :fail
             end

    result = Result.new(expectation: exp, actual: actual, status: status)
    @results << result
    print_result(result)
  end

  private def extract_hover_content(response)
    return nil if response&.dig("error")

    result = response&.dig("result")
    return nil unless result

    contents = result["contents"]
    if contents.is_a?(Hash)
      contents["value"]
    elsif contents.is_a?(Array)
      contents.map { |c| c.is_a?(Hash) ? c["value"] : c }.join("\n")
    else
      contents.to_s
    end
  end

  private def type_matches?(actual, expected)
    # Normalize for comparison:
    # - "bool" matches "TrueClass | FalseClass", "Boolean", "bool"
    # - "void" matches "void", "nil"
    # - Otherwise, check if expected string appears in actual (case-insensitive partial match)
    normalized_expected = expected.downcase.gsub(/\s+/, "")
    normalized_actual = actual.downcase.gsub(/\s+/, "")

    case normalized_expected
    when "bool"
      normalized_actual.match?(/bool|trueclass|falseclass|true\|false/)
    when "void"
      normalized_actual.match?(/void|nil/)
    else
      # Partial match: check if key parts of expected appear in actual
      # e.g., "String?" should match "() -> String?" or "String"
      key = normalized_expected.delete("?")
      normalized_actual.include?(key)
    end
  end

  # --- Reporting ---

  private def print_result(result)
    exp = result.expectation
    code = exp.code.length > 40 ? "#{exp.code[0, 37]}..." : exp.code
    labels = { pass: "\e[32mPASS\e[0m", fail: "\e[31mFAIL\e[0m", no_hover: "\e[33mSKIP\e[0m" }
    label = labels[result.status]

    line_info = format("L%-3d", exp.line)
    print format("  #{line_info} %-42s expected: %-25s #{label}", code, exp.expected)

    if result.status == :fail
      # Show first line of actual for debugging
      first_line = (result.actual || "").split("\n").first.to_s
      first_line = "#{first_line[0, 50]}..." if first_line.length > 50
      print "  got: #{first_line}"
    end

    puts
  end

  private def print_report
    puts
    pass = @results.count { |r| r.status == :pass }
    fail_count = @results.count { |r| r.status == :fail }
    skip = @results.count { |r| r.status == :no_hover }
    total = @results.size

    color = fail_count.zero? ? "\e[32m" : "\e[31m"
    puts "#{color}Results: #{pass} pass, #{fail_count} fail, #{skip} no_hover (#{total} total)\e[0m"

    return if fail_count.zero?

    puts
    puts "Failed expectations:"
    @results.select { |r| r.status == :fail }.each do |r|
      puts "  L#{r.expectation.line}: #{r.expectation.code}"
      puts "    expected: #{r.expectation.expected}"
      puts "    actual:   #{r.actual&.split("\n")&.first}"
      puts
    end
  end
end

# --- Main ---

if ARGV.empty? || ARGV.include?("--help") || ARGV.include?("-h")
  puts "Usage: bin/verify-inference <project_dir> [--verbose]"
  puts
  puts "Parses test_inference.rb in the project directory,"
  puts "hovers over each line with '# => Type' comment,"
  puts "and checks if the hover result matches the expected type."
  puts
  puts "Examples:"
  puts "  bin/verify-inference sample/activerecord"
  puts "  bin/verify-inference sample/mongoid --verbose"
  exit 0
end

verbose = ARGV.delete("--verbose") || ARGV.delete("-v")
project_dir = ARGV[0]

abort "Error: #{project_dir} is not a directory" unless File.directory?(project_dir)

verifier = InferenceVerifier.new(project_dir, verbose: !verbose.nil?)
verifier.run
